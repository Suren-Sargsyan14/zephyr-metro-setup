{
  "name": "Mini",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start --port 8082",
    "test": "jest",
    "build:android": "react-native bundle-mf-remote --platform android --dev false",
    "build:android:zephyr": "ZC=1 react-native bundle-mf-remote --platform android --dev false",
    "build:ios": "react-native bundle-mf-remote --platform ios --dev false",
    "build:ios:zephyr": "ZC=1 react-native bundle-mf-remote --platform ios --dev false",
    "serve:android": "npx --yes serve dist/android -p 8082",
    "serve:ios": "npx --yes serve dist/ios -p 8082",
    "adbreverse": "adb reverse tcp:8082 tcp:8082"
  },
  "dependencies": {
    "@module-federation/runtime": "0.21.6",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/native": "7.3.8",
    "@react-navigation/native-stack": "7.17.10",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.26.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@module-federation/metro": "0.21.6",
    "@module-federation/metro-plugin-rnc-cli": "0.21.6",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "zephyr-metro-plugin": "^1.1.2"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
